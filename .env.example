# Discord Thread Manager — The Hacky Way
# No token needed! The controller extracts it automatically.
# These settings are optional overrides.

# Optional: Custom CDP port (default: 9222)
# CDP_PORT=9222

# Optional: Channel ID for default scans
# DISCORD_CHANNEL_ID=123456789

# Optional: Discord binary path (auto-detected if not set)
# DISCORD_BIN_PATH=/usr/share/discord/Discord

# NOTE: You do NOT need to set DISCORD_TOKEN.
# The controller extracts your user token from the live session via CDP.
